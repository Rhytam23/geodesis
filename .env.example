# =============================================================================
# GEODESIS — Environment Variable Reference
# =============================================================================
#
# Copy this file to .env.local and fill in any values you want to override.
# Only variables prefixed with VITE_ are exposed to the browser bundle.
#
# NEVER commit .env or .env.local — they are in .gitignore.
# =============================================================================

# ── Public Data APIs ─────────────────────────────────────────────────────────
# These services are free and require no API key for basic usage.

# Open-Meteo — Real-time & forecast weather data (free, ECMWF model)
# Docs: https://open-meteo.com/en/docs
# Required: yes (falls back to deterministic demo data if unreachable)
VITE_OPENMETEO_BASE=https://api.open-meteo.com/v1

# WeatherAPI.com API Key — If provided, weather queries will run on WeatherAPI.com
# instead of Open-Meteo for higher confidence and detailed forecast descriptors.
# Required: no (falls back to Open-Meteo if not specified)
# VITE_WEATHER_API_KEY=your_weatherapi_key_here

# ISRIC SoilGrids v2.0 — Soil pH, organic carbon stock per coordinate
# Docs: https://rest.isric.org/soilgrids/v2.0/docs
# Required: yes (falls back to deterministic demo data if unreachable)
VITE_SOILGRIDS_BASE=https://rest.isric.org/soilgrids/v2.0

# OpenStreetMap Nominatim — Reverse geocoding (lat/lng → province/district)
# Docs: https://nominatim.org/release-docs/latest/api/Reverse/
# Required: yes (falls back to nearest mock province if unreachable)
# Rate limit: 1 req/sec per IP — do not exceed for production deployments
VITE_NOMINATIM_BASE=https://nominatim.openstreetmap.org

# ── Demo / Presentation ──────────────────────────────────────────────────────

# Force Demo Mode on for all sessions (useful for kiosk / presentation setups)
# Values: true | false
# Default: false
VITE_FORCE_DEMO_MODE=false

# ── Application ──────────────────────────────────────────────────────────────

# Public base URL (used for OG image and canonical link generation)
# Example: https://geodesis.vercel.app
# Required: no (defaults to window.location.origin)
# VITE_APP_URL=https://geodesis.vercel.app

# ── Backend (v1.1+) ──────────────────────────────────────────────────────────
# Uncomment when a backend API is deployed.

# Base URL for the Geodesis REST API
# Example: https://api.geodesis.vn/v1
# VITE_API_BASE_URL=

# SMS Gateway provider — used for farmer alert delivery
# Values: vnpt | twilio | custom
# VITE_SMS_GATEWAY=vnpt

# Google Earth Engine project ID
# Docs: https://earthengine.google.com/platform
# VITE_GEE_PROJECT_ID=

# ── Analytics & Monitoring (optional) ────────────────────────────────────────

# Sentry DSN — for production error tracking
# Docs: https://docs.sentry.io/platforms/javascript/guides/react/
# Free tier: 5,000 errors/month
# VITE_SENTRY_DSN=

# Sentry release identifier (usually set by CI, not manually)
# VITE_SENTRY_RELEASE=

# PostHog — product analytics (privacy-respecting alternative to GA)
# Docs: https://posthog.com/docs/integrate/client/js
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://app.posthog.com

# ── Notes ────────────────────────────────────────────────────────────────────
# All live services gracefully fall back to deterministic demonstration data.
# No secrets should ever be committed to the public repository.