# =============================================================================
# GEODESIS — .gitignore
# =============================================================================

# ----- Build Outputs -----
dist/
dist-ssr/
build/

# ----- Dependencies -----
node_modules/
.npm/

# ----- Environment / Secrets -----
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.crt
.next

# ----- Editor & OS -----
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- TypeScript -----
*.tsbuildinfo

# ----- Logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ----- Testing -----
coverage/
.nyc_output/
test-results/
playwright-report/

# ----- Cache -----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ----- Private / Internal -----
# Engineering artifacts, internal planning documents, sprint reports
# and AI workflow guides are stored in the private master repo.
# This is intentional — see private/README.md
private/

# ----- Vercel -----
.vercel/

# ----- Docker -----
.dockerignore

# ----- Misc -----
*.local
.history/
ruleset.json
