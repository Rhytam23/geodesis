{
  "name": "geodesis",
  "description": "Geospatial Digital Twin for Climate-Resilient Agriculture — Mekong Delta",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/your-org/geodesis",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/geodesis.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/geodesis/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "clean": "rimraf dist",
    "test": "vitest run",
    "ci": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.30",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.436.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "sonner": "^1.5.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.9.3",
    "vite": "^5.4.1",
    "vitest": "^1.6.0"
  }
}
